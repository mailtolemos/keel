generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / identity ----------
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String?
  image          String?
  isPlatformAdmin Boolean   @default(false)
  createdAt      DateTime   @default(now())
  employees      Employee[]
  resetTokens    PasswordResetToken[]
}

model Company {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  status        String         @default("active")
  country       String         @default("United States")
  workWeek      String         @default("Mon-Fri") // comma list of working days
  accentColor   String         @default("#4E2BD6")
  plan               String    @default("trial")
  subscriptionStatus String    @default("trialing")
  trialEndsAt        DateTime?
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String?
  stripePriceId      String?
  currentPeriodEnd   DateTime?
  createdAt     DateTime       @default(now())
  employees     Employee[]
  teams         Team[]
  leavePolicies LeavePolicy[]
  holidays      Holiday[]
  reviewCycles  ReviewCycle[]
  feedback      Feedback[]
  goals         Goal[]
  invitations   Invitation[]
}

// Role on the company workspace


model Employee {
  id             String         @id @default(cuid())
  company        Company        @relation(fields: [companyId], references: [id])
  companyId      String
  user           User?          @relation(fields: [userId], references: [id])
  userId         String?
  name           String
  title          String?
  workEmail      String
  personalEmail  String?
  location       String?
  employmentType String         @default("Full-time")
  startDate      DateTime?
  birthday       DateTime?
  photo          String?
  role           String           @default("EMPLOYEE")
  status         String @default("ACTIVE")
  adminNotes     String?        // visible only to admins/managers
  team           Team?          @relation("TeamMembers", fields: [teamId], references: [id])
  teamId         String?
  manager        Employee?      @relation("Reports", fields: [managerId], references: [id])
  managerId      String?
  reports        Employee[]     @relation("Reports")
  ledTeams       Team[]         @relation("TeamLead")
  memberships    Membership[]

  leaveRequests  LeaveRequest[]    @relation("LeaveOwner")
  reviewedLeave  LeaveRequest[]    @relation("LeaveApprover")
  reviewResponsesAuthored ReviewResponse[] @relation("ResponseAuthor")
  reviewResponsesSubject  ReviewResponse[] @relation("ResponseSubject")
  cycleParticipations     CycleParticipant[]
  feedbackGiven  Feedback[]       @relation("FeedbackAuthor")
  feedbackGotten Feedback[]       @relation("FeedbackSubject")
  goalsOwned     Goal[]           @relation("GoalOwner")
  goalUpdates    GoalUpdate[]
  oneOnOnesAsManager OneOnOne[]   @relation("OneOnOneManager")
  oneOnOnesAsReport  OneOnOne[]   @relation("OneOnOneReport")

  @@unique([companyId, userId])
  @@index([companyId])
}

model Team {
  id          String       @id @default(cuid())
  company     Company      @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  description String?
  lead        Employee?    @relation("TeamLead", fields: [leadId], references: [id])
  leadId      String?
  parent      Team?        @relation("SubTeams", fields: [parentId], references: [id])
  parentId    String?
  children    Team[]       @relation("SubTeams")
  members     Employee[]   @relation("TeamMembers")
  memberships Membership[]
  goals       Goal[]
  createdAt   DateTime     @default(now())

  @@index([companyId])
}

// Explicit membership join (supports a person belonging to extra teams)
model Membership {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  team       Team     @relation(fields: [teamId], references: [id])
  teamId     String
  title      String?
  isLead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([employeeId, teamId])
}

// ---------- Leave ----------


model LeavePolicy {
  id            String     @id @default(cuid())
  company       Company    @relation(fields: [companyId], references: [id])
  companyId     String
  name          String
  type          String  @default("VACATION")
  allowanceDays Int        @default(25)
  paid          Boolean    @default(true)
  createdAt     DateTime   @default(now())
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employee   Employee    @relation("LeaveOwner", fields: [employeeId], references: [id])
  employeeId String
  type       String   @default("VACATION")
  startDate  DateTime
  endDate    DateTime
  days       Float       @default(1)
  reason     String?
  status     String @default("PENDING")
  approver   Employee?   @relation("LeaveApprover", fields: [approverId], references: [id])
  approverId String?
  decidedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@index([employeeId])
}

model Holiday {
  id        String   @id @default(cuid())
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String
  name      String
  date      DateTime
  calendar  String   @default("Company")
}

// ---------- Performance reviews ----------

model ReviewCycle {
  id          String             @id @default(cuid())
  company     Company            @relation(fields: [companyId], references: [id])
  companyId   String
  name        String
  periodStart DateTime?
  periodEnd   DateTime?
  dueDate     DateTime?
  selfReview  Boolean            @default(true)
  managerReview Boolean          @default(true)
  peerReview  Boolean            @default(false)
  upwardReview Boolean           @default(false)
  ratingScale Boolean            @default(true)
  status      String        @default("DRAFT")
  createdAt   DateTime           @default(now())
  questions   ReviewQuestion[]
  participants CycleParticipant[]
  responses   ReviewResponse[]
}

model ReviewQuestion {
  id        String      @id @default(cuid())
  cycle     ReviewCycle @relation(fields: [cycleId], references: [id])
  cycleId   String
  prompt    String
  order     Int         @default(0)
  hasRating Boolean     @default(true)
}

model CycleParticipant {
  id         String      @id @default(cuid())
  cycle      ReviewCycle @relation(fields: [cycleId], references: [id])
  cycleId    String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  employeeId String

  @@unique([cycleId, employeeId])
}


model ReviewResponse {
  id         String         @id @default(cuid())
  cycle      ReviewCycle    @relation(fields: [cycleId], references: [id])
  cycleId    String
  kind       String     @default("SELF")
  author     Employee       @relation("ResponseAuthor", fields: [authorId], references: [id])
  authorId   String
  subject    Employee       @relation("ResponseSubject", fields: [subjectId], references: [id])
  subjectId  String
  status     String @default("NOT_STARTED")
  summary    String?
  growth     String?        // growth recommendations
  overallRating Int?
  answers    String?          // [{questionId, text, rating}]
  submittedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([cycleId])
}

// ---------- Continuous feedback ----------

model Feedback {
  id         String             @id @default(cuid())
  company    Company            @relation(fields: [companyId], references: [id])
  companyId  String
  author     Employee           @relation("FeedbackAuthor", fields: [authorId], references: [id])
  authorId   String
  subject    Employee           @relation("FeedbackSubject", fields: [subjectId], references: [id])
  subjectId  String
  body       String
  tags       String             @default("") // comma list: Strength,Improvement,...
  visibility String @default("PUBLIC")
  isRequest  Boolean            @default(false)
  createdAt  DateTime           @default(now())

  @@index([companyId])
}

// ---------- Goals ----------

model Goal {
  id          String       @id @default(cuid())
  company     Company      @relation(fields: [companyId], references: [id])
  companyId   String
  title       String
  description String?
  level       String    @default("INDIVIDUAL")
  owner       Employee?    @relation("GoalOwner", fields: [ownerId], references: [id])
  ownerId     String?
  team        Team?        @relation(fields: [teamId], references: [id])
  teamId      String?
  dueDate     DateTime?
  status      String   @default("ON_TRACK")
  progress    Int          @default(0)
  createdAt   DateTime     @default(now())
  updates     GoalUpdate[]
}

model GoalUpdate {
  id        String   @id @default(cuid())
  goal      Goal     @relation(fields: [goalId], references: [id])
  goalId    String
  author    Employee @relation(fields: [authorId], references: [id])
  authorId  String
  body      String
  progress  Int?
  createdAt DateTime @default(now())
}

// ---------- 1:1s ----------
model OneOnOne {
  id         String          @id @default(cuid())
  manager    Employee        @relation("OneOnOneManager", fields: [managerId], references: [id])
  managerId  String
  report     Employee        @relation("OneOnOneReport", fields: [reportId], references: [id])
  reportId   String
  cadence    String          @default("Weekly")
  nextAt     DateTime?
  createdAt  DateTime        @default(now())
  notes      OneOnOneNote[]
}

model OneOnOneNote {
  id          String   @id @default(cuid())
  oneOnOne    OneOnOne @relation(fields: [oneOnOneId], references: [id])
  oneOnOneId  String
  meetingDate DateTime @default(now())
  agenda      String?
  sharedNotes String?
  privateNotes String?  // visible only to author
  privateFor  String?   // employeeId who owns the private note
  actionItems String?     // [{text, done}]
  createdAt   DateTime @default(now())
}

// ---------- Invitations ----------

model Invitation {
  id         String       @id @default(cuid())
  company    Company      @relation(fields: [companyId], references: [id])
  companyId  String
  email      String
  name       String
  role       String         @default("EMPLOYEE")
  title      String?
  teamId     String?
  token      String       @unique @default(cuid())
  status     String @default("PENDING")
  createdAt  DateTime     @default(now())
}

// ---------- Product changelog (homepage "what's new") ----------
model Changelog {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("Feature") // Feature | Improvement | Fix
  summary   String
  changes   String   @default("")        // newline-separated bullet points
  date      DateTime @default(now())
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
