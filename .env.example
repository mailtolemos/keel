# ---- Database (Neon Postgres) ----
# When you add Neon from the Vercel dashboard (Storage -> Create Database -> Neon),
# Vercel injects DATABASE_URL automatically. For LOCAL setup/seeding, paste a Neon
# connection string here (use the "unpooled"/direct one for prisma db push):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- Auth ----
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Local: http://localhost:3000  ·  Production: your deployed URL
NEXTAUTH_URL="http://localhost:3000"

# ---- Optional: Google sign-in ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- App URL (for email links & Stripe redirects) ----
NEXT_PUBLIC_APP_URL="https://www.mykeel.org"

# ---- Transactional email (Resend) — optional; invites/resets show a link if unset ----
RESEND_API_KEY=""
EMAIL_FROM="Keel <noreply@yourdomain.com>"

# ---- Billing (Stripe) — optional; billing UI shows "not configured" if unset ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
