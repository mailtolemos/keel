{
  "name": "keel",
  "version": "1.0.0",
  "private": true,
  "description": "Keel \u2014 the backbone of high-performing teams. An adaptive people operating system.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "prisma db push && prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "next": "14.2.21",
    "next-auth": "4.24.11",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8",
    "next-themes": "0.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.6",
    "tsx": "4.16.2",
    "typescript": "5.5.3"
  }
}